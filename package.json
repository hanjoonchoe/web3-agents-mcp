{
  "name": "mcp-8004-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "MCP bridge server (pre-alpha).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json && node dist/server/index.js",
    "build": "tsc -p tsconfig.json && mkdir -p dist/registry/abi && cp src/registry/abi/*.json dist/registry/abi/",
    "test": "vitest run --exclude \"**/*.fork.test.ts\"",
    "test:fork": "vitest run test/registry/identity.fork.test.ts",
    "lint": "eslint . && prettier --check \"**/*.{ts,js,json,md,yml}\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "multiformats": "^14.0.4",
    "viem": "^2.55.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
