{
  "name": "web3-agents-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for on-chain AI agents — discover, inspect, and verify blockchain-registered agents (ERC-8004) from any MCP client.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "web3-agents-mcp": "dist/server/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "erc-8004",
    "ethereum",
    "trustless-agents",
    "ai-agents"
  ],
  "scripts": {
    "dev": "tsc -p tsconfig.json && node dist/server/index.js",
    "build": "tsc -p tsconfig.json && mkdir -p dist/registry/abi && cp src/registry/abi/*.json dist/registry/abi/",
    "test": "vitest run --exclude \"**/*.fork.test.ts\"",
    "test:fork": "vitest run test/registry/identity.fork.test.ts test/registry/reputation.fork.test.ts",
    "lint": "eslint . && prettier --check \"**/*.{ts,js,json,md,yml}\" \"!docs/tools.md\" --ignore-path .gitignore",
    "typecheck": "tsc --noEmit",
    "docs:gen": "pnpm build && node scripts/gen-tool-docs.ts",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "multiformats": "^14.0.4",
    "viem": "^2.55.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
